# ─────────────────────────────────────────────────────────────
# Sherlock — local environment (copy to .env; .env is git-ignored)
# ─────────────────────────────────────────────────────────────

# ── Kafka ──────────────────────────────────────
# From the host (e.g. IDE, host-run apps, smoke test on host):
KAFKA_BOOTSTRAP_HOST=localhost:29092
# From inside the docker network (services):
KAFKA_BOOTSTRAP_INTERNAL=kafka:9092
SCHEMA_REGISTRY_URL=http://localhost:8081

# ── Postgres ───────────────────────────────────
POSTGRES_USER=sherlock
POSTGRES_PASSWORD=sherlock
POSTGRES_DB=sherlock
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Redis ──────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── MinIO (S3-compatible object store) ─────────
MINIO_ROOT_USER=sherlock
MINIO_ROOT_PASSWORD=sherlock123
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET_MEDIA=sherlock-media
MINIO_BUCKET_EMBEDDINGS=sherlock-embeddings

# ── Kafka UI ───────────────────────────────────
KAFKA_UI_PORT=8080
